+}
+
+.dashboard-container {
+  text-align: center;
+}
+
+.dashboard-container p {
+  color: var(--text-muted);
+  margin-bottom: 1.5rem;
+}
+
+@keyframes slideUp {
+  from {
+    opacity: 0;
+    transform: translateY(20px);
+  }
